# Copy to .dev.vars and fill in values. Never commit .dev.vars.

# ── Cloudflare credentials ────────────────────────────────────────────────────
# wrangler reads CLOUDFLARE_API_TOKEN and CLOUDFLARE_ACCOUNT_ID from the shell
# environment, not from this file. The `deploy` npm script wraps wrangler with
# `dotenv -e .dev.vars --` so these values get injected automatically:
#   npm run deploy
# For other wrangler CLI commands (D1 setup, etc.), prefix with:
#   npx dotenv -e .dev.vars -- wrangler <command>
# Pinning the account here also ensures deploys go to the correct Cloudflare
# account even when `wrangler login` is authenticated as a different account.
#
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ── GitHub OAuth App credentials ──────────────────────────────────────────────
# Settings → Developer settings → OAuth Apps → New OAuth App
# Callback URL: https://<your-pages-domain>/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Session signing ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=
