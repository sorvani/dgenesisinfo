# Copy to .dev.vars and fill in values. Never commit .dev.vars.

# Cloudflare credentials for this account (scopes: D1, Pages)
# Account ID: right sidebar of any Cloudflare dashboard page
# API Token:  dash.cloudflare.com/profile/api-tokens → Create Token → Edit Cloudflare Workers template
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# GitHub OAuth App credentials (Settings → Developer settings → OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Random secret for signing — generate with: openssl rand -hex 32
SESSION_SECRET=
